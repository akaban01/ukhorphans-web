---
import { getEntry } from 'astro:content';
import Icon from './Icon.astro';

const settings = await getEntry('settings', 'main');
const s = settings!.data;

const nav = [
  { href: '/', label: 'Home' },
  { href: '/about-us', label: 'About Us' },
  { href: '/missions', label: 'Missions' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];

const current = Astro.url.pathname;
---

<div class="bg-ink-900 text-ink-200 text-sm">
  <div class="container-page flex flex-wrap items-center justify-between gap-2 py-2">
    <a href={`tel:${s.phone.replace(/[^+\d]/g, '')}`} class="flex items-center gap-2 hover:text-gold-300 transition-colors">
      <Icon name="phone" class="size-4" />
      <span>{s.phone}</span>
    </a>
    <a href={`mailto:${s.email}`} class="flex items-center gap-2 hover:text-gold-300 transition-colors">
      <Icon name="mail" class="size-4" />
      <span>{s.email}</span>
    </a>
  </div>
</div>

<header class="sticky top-0 z-50 bg-ink-800/95 backdrop-blur supports-[backdrop-filter]:bg-ink-800/90 border-b border-ink-600/40">
  <div class="container-page flex items-center justify-between py-3">
    <a href="/" class="flex items-center gap-3 shrink-0">
      <span class="flex size-11 items-center justify-center rounded-full bg-gold-400 text-ink-900">
        <Icon name="heart" class="size-6" />
      </span>
      <span class="font-display leading-tight">
        <span class="block text-base font-semibold text-white tracking-wide">Ummul Khairi</span>
        <span class="block text-xs uppercase tracking-[0.2em] text-gold-300">House of Orphans</span>
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-8 font-medium text-ink-200">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'hover:text-gold-300 transition-colors',
            current === item.href || (item.href !== '/' && current.startsWith(item.href))
              ? 'text-gold-300'
              : '',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href={s.donateUrl}
      class="hidden lg:inline-flex items-center gap-2 rounded-full bg-gold-400 px-5 py-2.5 font-semibold text-ink-900 hover:bg-gold-300 transition-colors"
    >
      Donate Now
      <Icon name="arrow" class="size-4" />
    </a>

    <details class="lg:hidden relative group">
      <summary class="list-none cursor-pointer rounded-md p-2 text-ink-200 hover:bg-ink-600/40 [&::-webkit-details-marker]:hidden">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      </summary>
      <div class="hidden group-open:flex absolute right-0 top-full mt-2 w-56 rounded-xl bg-ink-800 border border-ink-600/50 shadow-xl p-3 flex-col gap-1">
        {nav.map((item) => (
          <a href={item.href} class="rounded-lg px-3 py-2 text-ink-200 hover:bg-ink-600/40 hover:text-gold-300 transition-colors">
            {item.label}
          </a>
        ))}
        <a href={s.donateUrl} class="mt-1 rounded-lg bg-gold-400 px-3 py-2 text-center font-semibold text-ink-900 hover:bg-gold-300 transition-colors">
          Donate Now
        </a>
      </div>
    </details>
  </div>
</header>
