---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import { getEntry } from 'astro:content';

const settings = await getEntry('settings', 'main');
const s = settings!.data;

const amounts = ['25', '50', '100', '250'];
---

<Layout title="Donate" description="Support Ummul Khairi House of Orphans with a one-time or monthly gift.">
  <PageHero title="Make a Donation" subtitle="Every gift helps us provide shelter, food, and education to a child in Kaolack, Senegal." />

  <section class="py-20 sm:py-28">
    <div class="container-page grid gap-12 lg:grid-cols-5">
      <div class="lg:col-span-3 rounded-3xl bg-white p-8 shadow-sm ring-1 ring-ink-900/5">
        <div class="flex rounded-full bg-cream-100 p-1 text-sm font-semibold">
          <button type="button" class="flex-1 rounded-full bg-gold-400 px-4 py-2 text-ink-900" aria-pressed="true">
            One-Time
          </button>
          <button type="button" class="flex-1 rounded-full px-4 py-2 text-ink-400" aria-pressed="false">
            Monthly
          </button>
        </div>

        <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
          {amounts.map((amount) => (
            <button type="button" class="rounded-xl border border-ink-900/10 py-3 font-semibold text-ink-900 hover:border-gold-400 hover:bg-gold-50 transition-colors">
              ${amount}
            </button>
          ))}
        </div>

        <div class="mt-6">
          <label for="custom-amount" class="text-sm font-semibold text-ink-800">Custom Amount (USD)</label>
          <div class="mt-2 flex items-center rounded-xl border border-ink-900/10 bg-cream px-4 py-3 focus-within:ring-2 focus-within:ring-gold-400">
            <span class="text-ink-400">$</span>
            <input id="custom-amount" type="number" min="1" placeholder="0.00" class="w-full bg-transparent pl-2 text-ink-900 focus:outline-none" />
          </div>
        </div>

        <a
          href={`mailto:${s.email}?subject=${encodeURIComponent('Donation Inquiry')}`}
          class="mt-8 flex w-full items-center justify-center gap-2 rounded-full bg-gold-400 px-6 py-3.5 font-semibold text-ink-900 hover:bg-gold-300 transition-colors"
        >
          Continue to Donate <Icon name="arrow" class="size-4" />
        </a>
        <p class="mt-3 text-center text-xs text-ink-400">
          Secure checkout is not yet connected — this button currently reaches our team directly by email so
          we can process your gift. Contact us to set up a payment processor (e.g. Stripe or PayPal).
        </p>
      </div>

      <div class="lg:col-span-2 space-y-6">
        <div class="rounded-2xl bg-ink-900 p-8 text-white">
          <h2 class="font-display text-xl font-semibold">Other Ways to Give</h2>
          <ul class="mt-4 space-y-4 text-sm text-ink-200">
            <li class="flex items-start gap-3">
              <Icon name="mail" class="size-5 shrink-0 text-gold-300" />
              <span>Email <a class="underline hover:text-gold-300" href={`mailto:${s.email}`}>{s.email}</a> to arrange a bank transfer or check.</span>
            </li>
            <li class="flex items-start gap-3">
              <Icon name="phone" class="size-5 shrink-0 text-gold-300" />
              <span>Call us at {s.phone} to discuss recurring or in-kind giving.</span>
            </li>
            <li class="flex items-start gap-3">
              <Icon name="pin" class="size-5 shrink-0 text-gold-300" />
              <span>Mail a check to {s.address}.</span>
            </li>
          </ul>
        </div>
        <div class="rounded-2xl bg-gold-50 p-8">
          <h2 class="font-display text-xl font-semibold text-ink-900">Your Impact</h2>
          <ul class="mt-4 space-y-3 text-sm text-ink-600">
            <li class="flex items-center gap-2"><Icon name="check" class="size-4 text-gold-600" /> $25 provides a week of meals for one child</li>
            <li class="flex items-center gap-2"><Icon name="check" class="size-4 text-gold-600" /> $50 covers school supplies for a term</li>
            <li class="flex items-center gap-2"><Icon name="check" class="size-4 text-gold-600" /> $100 helps furnish a shared dormitory room</li>
            <li class="flex items-center gap-2"><Icon name="check" class="size-4 text-gold-600" /> $250 supports a caregiver's monthly stipend</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</Layout>
