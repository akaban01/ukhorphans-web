---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getCollection, getEntry } from 'astro:content';

const settings = await getEntry('settings', 'main');
const s = settings!.data;

const missions = (await getCollection('missions')).sort((a, b) => a.data.order - b.data.order);
const team = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order).slice(0, 3);
const posts = (await getCollection('blog')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);

const stats = [
  { label: 'Children Supported', value: '120+' },
  { label: 'Meals Served Monthly', value: '3,600' },
  { label: 'Dedicated Caregivers', value: '18' },
  { label: 'Years Serving', value: '5' },
];
---

<Layout title="Home">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-ink-900">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute -left-32 top-10 size-96 rounded-full bg-gold-400/20 blur-3xl"></div>
      <div class="absolute right-0 -bottom-32 size-[28rem] rounded-full bg-gold-500/20 blur-3xl"></div>
    </div>
    <div class="container-page relative grid gap-12 py-20 sm:py-28 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="font-display italic text-lg text-gold-300">Building Hope</p>
        <h1 class="mt-3 font-display text-4xl font-semibold leading-tight text-white sm:text-5xl lg:text-6xl">
          Providing Shelter and<br class="hidden sm:block" /> Nurturing Hearts
        </h1>
        <p class="mt-6 max-w-xl text-ink-200 leading-relaxed">
          Every child deserves a bright future filled with love, care, and opportunity. We're building an
          orphanage in the vibrant city of Kaolack, Senegal, to give the most vulnerable among us — the
          orphans — shelter, food, and education.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href={s.donateUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full bg-gold-400 px-6 py-3 font-semibold text-ink-900 hover:bg-gold-300 transition-colors">
            Donate Now <Icon name="arrow" class="size-4" />
          </a>
          <a href="/about-us" class="inline-flex items-center gap-2 rounded-full border border-ink-200/30 px-6 py-3 font-semibold text-white hover:bg-ink-600/40 transition-colors">
            Learn Our Story
          </a>
        </div>
      </div>

      <div class="relative">
        <div class="aspect-4/3 rounded-3xl bg-gradient-to-br from-gold-300 via-gold-400 to-gold-600 p-1.5 shadow-2xl">
          <div class="flex h-full w-full items-center justify-center rounded-[1.3rem] bg-white p-8">
            <img
              src="/images/logo.jpeg"
              alt="Ummul Khairi House of Orphans"
              width="700"
              height="617"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="h-full w-full object-contain"
            />
          </div>
        </div>
        <div class="absolute bottom-4 left-4 sm:-bottom-6 sm:-left-6 rounded-2xl bg-white px-6 py-4 shadow-xl">
          <p class="font-display text-2xl font-semibold text-ink-900">Kaolack, Senegal</p>
          <p class="text-sm text-ink-400">Our orphanage site</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Strategic priorities strip -->
  <section class="bg-gold-400">
    <div class="container-page grid grid-cols-1 divide-y divide-ink-900/10 py-2 sm:grid-cols-3 sm:divide-x sm:divide-y-0">
      {missions.map((m) => (
        <div class="flex items-center justify-center gap-3 px-6 py-4 text-ink-900">
          <Icon name={m.data.icon} class="size-6" />
          <span class="font-display text-lg font-semibold">{m.data.title}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Our Project -->
  <section class="py-20 sm:py-28">
    <div class="container-page grid gap-12 lg:grid-cols-2 lg:items-center">
      <div class="order-2 lg:order-1">
        <div class="grid grid-cols-2 gap-4">
          <img src="/images/groundbreaking-ceremony.jpg" alt="Laying the first brick at the groundbreaking ceremony" width="859" height="859" loading="lazy" decoding="async" class="aspect-square rounded-2xl object-cover" />
          <img src="/images/caregiver-embracing-children.jpg" alt="A caregiver embracing two children in her care" width="700" height="700" loading="lazy" decoding="async" class="mt-8 aspect-square rounded-2xl object-cover" />
        </div>
      </div>
      <div class="order-1 lg:order-2">
        <SectionHeading eyebrow="Our Project" title="A secure, stable home for every child" align="left" />
        <p class="mt-6 text-ink-600 leading-relaxed">
          By offering children a secure and stable home, we hope to give them a sense of belonging and the
          opportunity to grow and thrive. Our orphanage will have comfortable living spaces, nutritious
          meals, and access to healthcare facilities. We strongly believe that a warm and caring environment
          is essential to their overall wellbeing.
        </p>
        <ul class="mt-6 space-y-3">
          {['Provide Shelter', 'Clothing', 'Food & Water', 'Free Education'].map((item) => (
            <li class="flex items-center gap-3 text-ink-800">
              <span class="flex size-6 items-center justify-center rounded-full bg-gold-400/20 text-gold-600">
                <Icon name="check" class="size-3.5" />
              </span>
              {item}
            </li>
          ))}
        </ul>
        <a href="/donate" class="mt-8 inline-flex items-center gap-2 rounded-full bg-ink-900 px-6 py-3 font-semibold text-white hover:bg-ink-800 transition-colors">
          Make a Donation <Icon name="arrow" class="size-4" />
        </a>
      </div>
    </div>
  </section>

  <!-- What We Do (latest posts) -->
  <section class="bg-cream-100 py-20 sm:py-28">
    <div class="container-page">
      <SectionHeading eyebrow="What We Do" title="Recent updates from the ground" />
      <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="group flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-ink-900/5 hover:shadow-lg transition-shadow">
            {post.data.image ? (
              <img src={post.data.image} alt={post.data.title} loading="lazy" decoding="async" class="h-40 w-full object-cover" />
            ) : (
              <div class="flex h-40 w-full items-center justify-center bg-gold-50">
                <Icon name="heart" class="size-10 text-gold-400" />
              </div>
            )}
            <div class="flex flex-1 flex-col p-6">
            <p class="text-xs font-semibold uppercase tracking-wider text-gold-600">
              {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' })}
            </p>
            <h3 class="mt-3 font-display text-xl font-semibold text-ink-900 group-hover:text-gold-600 transition-colors">
              {post.data.title}
            </h3>
            <p class="mt-3 text-sm text-ink-400 leading-relaxed line-clamp-3">{post.data.excerpt}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-gold-600">
              Read More <Icon name="arrow" class="size-3.5" />
            </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Education CTA -->
  <section class="py-20 sm:py-28">
    <div class="container-page grid gap-12 lg:grid-cols-2 lg:items-center">
      <div>
        <SectionHeading eyebrow="Education" title="Help us unlock a bright future for children" align="left" />
        <p class="mt-6 text-ink-600 leading-relaxed">
          Education is the key to unlocking a brighter future for these young souls. We believe that by
          providing them with quality education, we are giving them the tools they need to succeed.
        </p>
        <a href="/donate" class="mt-8 inline-flex items-center gap-2 rounded-full bg-gold-400 px-6 py-3 font-semibold text-ink-900 hover:bg-gold-300 transition-colors">
          Make Donation <Icon name="arrow" class="size-4" />
        </a>
      </div>
      <div class="aspect-video overflow-hidden rounded-3xl bg-ink-900">
        <video src="/videos/hero-video.mp4" controls preload="metadata" class="h-full w-full object-cover"></video>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="bg-ink-900 py-20 sm:py-28">
    <div class="container-page">
      <SectionHeading eyebrow="Meet Our Team" title="Leaders dedicated to the well-being of children" light />
      <div class="mt-12 grid gap-8 sm:grid-cols-3">
        {team.map((member) => (
          <div class="rounded-2xl bg-ink-800 p-6 text-center ring-1 ring-white/5">
            {member.data.photo ? (
              <img src={member.data.photo} alt={member.data.name} loading="lazy" decoding="async" class="mx-auto size-20 rounded-full object-cover" />
            ) : (
              <div class="mx-auto flex size-20 items-center justify-center rounded-full bg-gold-400/20">
                <Icon name="users" class="size-9 text-gold-300" />
              </div>
            )}
            <h3 class="mt-4 font-display text-lg font-semibold text-white">{member.data.name}</h3>
            <p class="text-sm text-gold-300">{member.data.role}</p>
          </div>
        ))}
      </div>
      <div class="mt-10 text-center">
        <a href="/about-us" class="inline-flex items-center gap-2 rounded-full border border-white/20 px-6 py-3 font-semibold text-white hover:bg-ink-600/40 transition-colors">
          Become a Volunteer <Icon name="arrow" class="size-4" />
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-20 sm:py-28">
    <div class="container-page">
      <SectionHeading eyebrow="Together We Can" title="Make a difference, one child at a time" />
      <div class="mt-12 grid grid-cols-2 gap-8 sm:grid-cols-4">
        {stats.map((stat) => (
          <div class="text-center">
            <p class="font-display text-4xl font-semibold text-gold-600">{stat.value}</p>
            <p class="mt-2 text-sm text-ink-400">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="pb-20 sm:pb-28">
    <div class="container-page">
      <div class="relative overflow-hidden rounded-3xl bg-gold-400 px-8 py-16 text-center sm:px-16">
        <div class="pointer-events-none absolute -right-20 -top-20 size-72 rounded-full bg-white/20 blur-3xl" aria-hidden="true"></div>
        <h2 class="font-display text-3xl font-semibold text-ink-900 sm:text-4xl">
          Become a volunteer and change a life today
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-ink-800/80">
          Every day we bring hope to children who need it most. Join us as a volunteer or contact our team
          to learn how you can help.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a href="/contact" class="inline-flex items-center gap-2 rounded-full bg-ink-900 px-6 py-3 font-semibold text-white hover:bg-ink-800 transition-colors">
            Contact Us
          </a>
          <a href={s.donateUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 font-semibold text-ink-900 hover:bg-cream transition-colors">
            Donate Now <Icon name="arrow" class="size-4" />
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
