---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import { getCollection, render } from 'astro:content';

const missionsRaw = (await getCollection('missions')).sort((a, b) => a.data.order - b.data.order);
const missions = await Promise.all(
  missionsRaw.map(async (m) => ({ mission: m, Content: (await render(m)).Content }))
);
---

<Layout title="Missions" description="Our strategic priorities: shelter, food, and education for orphans in Kaolack, Senegal.">
  <PageHero title="Our Missions" subtitle="Three strategic priorities guide everything we do — shelter, feed, and educate." />

  <section class="py-20 sm:py-28">
    <div class="container-page grid gap-8 md:grid-cols-3">
      {missions.map(({ mission, Content }) => (
        <div class="rounded-3xl bg-white p-8 shadow-sm ring-1 ring-ink-900/5">
          <div class="flex size-14 items-center justify-center rounded-2xl bg-gold-400/15 text-gold-500">
            <Icon name={mission.data.icon} class="size-7" />
          </div>
          <h2 class="mt-6 font-display text-2xl font-semibold text-ink-900">{mission.data.title}</h2>
          <div class="mt-3 text-sm text-ink-500 leading-relaxed [&_p]:m-0">
            <Content />
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-ink-900 py-20 sm:py-28">
    <div class="container-page grid gap-10 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="font-display italic text-gold-300">How We Work</p>
        <h2 class="mt-2 font-display text-3xl font-semibold text-white sm:text-4xl">
          Every day we bring hope to children
        </h2>
        <p class="mt-6 text-ink-200 leading-relaxed">
          From the moment a child arrives, our team focuses on stability first: a bed, a meal, and a
          caregiver who knows their name. From there, we build outward — schooling, healthcare, community,
          and the everyday joys of childhood.
        </p>
        <a href="/donate" class="mt-8 inline-flex items-center gap-2 rounded-full bg-gold-400 px-6 py-3 font-semibold text-ink-900 hover:bg-gold-300 transition-colors">
          Support This Work <Icon name="arrow" class="size-4" />
        </a>
      </div>
      <div class="aspect-video rounded-3xl bg-ink-800 flex items-center justify-center ring-1 ring-white/10">
        <button aria-label="Watch video" class="flex size-20 items-center justify-center rounded-full bg-gold-400 text-ink-900 hover:bg-gold-300 transition-colors">
          <Icon name="play" class="size-8" />
        </button>
      </div>
    </div>
  </section>
</Layout>
