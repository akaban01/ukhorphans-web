---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import { getEntry } from 'astro:content';

const settings = await getEntry('settings', 'main');
const s = settings!.data;
---

<Layout title="Contact" description="Get in touch with Ummul Khairi House of Orphans.">
  <PageHero title="Contact Us" subtitle="We'd love to hear from you — questions, partnerships, or ways to help." />

  <section class="py-20 sm:py-28">
    <div class="container-page grid gap-12 lg:grid-cols-5">
      <div class="lg:col-span-2 space-y-6">
        <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-ink-900/5 flex items-start gap-4">
          <span class="flex size-11 shrink-0 items-center justify-center rounded-full bg-gold-400/15 text-gold-500">
            <Icon name="phone" class="size-5" />
          </span>
          <div>
            <p class="font-semibold text-ink-900">Call Us</p>
            <p class="text-sm text-ink-400">{s.phone}</p>
          </div>
        </div>
        <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-ink-900/5 flex items-start gap-4">
          <span class="flex size-11 shrink-0 items-center justify-center rounded-full bg-gold-400/15 text-gold-500">
            <Icon name="mail" class="size-5" />
          </span>
          <div>
            <p class="font-semibold text-ink-900">Email Us</p>
            <p class="text-sm text-ink-400">{s.email}</p>
          </div>
        </div>
        <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-ink-900/5 flex items-start gap-4">
          <span class="flex size-11 shrink-0 items-center justify-center rounded-full bg-gold-400/15 text-gold-500">
            <Icon name="pin" class="size-5" />
          </span>
          <div>
            <p class="font-semibold text-ink-900">Mailing Address</p>
            <p class="text-sm text-ink-400">{s.address}</p>
          </div>
        </div>
      </div>

      <form class="lg:col-span-3 rounded-3xl bg-white p-8 shadow-sm ring-1 ring-ink-900/5 space-y-5" name="contact" method="POST" data-netlify="true">
        <input type="hidden" name="form-name" value="contact" />
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label for="name" class="text-sm font-semibold text-ink-800">Full Name</label>
            <input id="name" name="name" type="text" required class="mt-2 w-full rounded-xl border border-ink-900/10 bg-cream px-4 py-3 text-ink-900 focus:outline-none focus:ring-2 focus:ring-gold-400" />
          </div>
          <div>
            <label for="email" class="text-sm font-semibold text-ink-800">Email</label>
            <input id="email" name="email" type="email" required class="mt-2 w-full rounded-xl border border-ink-900/10 bg-cream px-4 py-3 text-ink-900 focus:outline-none focus:ring-2 focus:ring-gold-400" />
          </div>
        </div>
        <div>
          <label for="subject" class="text-sm font-semibold text-ink-800">Subject</label>
          <input id="subject" name="subject" type="text" class="mt-2 w-full rounded-xl border border-ink-900/10 bg-cream px-4 py-3 text-ink-900 focus:outline-none focus:ring-2 focus:ring-gold-400" />
        </div>
        <div>
          <label for="message" class="text-sm font-semibold text-ink-800">Message</label>
          <textarea id="message" name="message" rows="5" required class="mt-2 w-full rounded-xl border border-ink-900/10 bg-cream px-4 py-3 text-ink-900 focus:outline-none focus:ring-2 focus:ring-gold-400"></textarea>
        </div>
        <button type="submit" class="inline-flex items-center gap-2 rounded-full bg-gold-400 px-6 py-3 font-semibold text-ink-900 hover:bg-gold-300 transition-colors">
          Send Message <Icon name="arrow" class="size-4" />
        </button>
      </form>
    </div>
  </section>
</Layout>
