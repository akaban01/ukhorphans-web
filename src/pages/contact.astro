---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import { getEntry } from 'astro:content';

const settings = await getEntry('settings', 'main');
const s = settings!.data;
---

<Layout title="Contact" description="Get in touch with Ummul Khairi House of Orphans.">
  <PageHero title="Contact Us" subtitle="We'd love to hear from you — questions, partnerships, or ways to help." />

  <section class="py-20 sm:py-28">
    <div class="container-page grid gap-6 sm:grid-cols-3 max-w-4xl mx-auto">
      <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-ink-900/5 flex items-start gap-4">
        <span class="flex size-11 shrink-0 items-center justify-center rounded-full bg-gold-400/15 text-gold-500">
          <Icon name="phone" class="size-5" />
        </span>
        <div>
          <p class="font-semibold text-ink-900">Call Us</p>
          <p class="text-sm text-ink-400">{s.phone}</p>
        </div>
      </div>
      <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-ink-900/5 flex items-start gap-4">
        <span class="flex size-11 shrink-0 items-center justify-center rounded-full bg-gold-400/15 text-gold-500">
          <Icon name="mail" class="size-5" />
        </span>
        <div>
          <p class="font-semibold text-ink-900">Email Us</p>
          <p class="text-sm text-ink-400">{s.email}</p>
        </div>
      </div>
      <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-ink-900/5 flex items-start gap-4">
        <span class="flex size-11 shrink-0 items-center justify-center rounded-full bg-gold-400/15 text-gold-500">
          <Icon name="pin" class="size-5" />
        </span>
        <div>
          <p class="font-semibold text-ink-900">Mailing Address</p>
          <p class="text-sm text-ink-400">{s.address}</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
